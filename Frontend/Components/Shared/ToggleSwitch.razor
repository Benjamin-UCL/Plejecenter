@namespace Frontend.Components.Shared

@* ============================================================
   KOMPONENT: ToggleSwitch
   FORMÅL: Genbrugelig on/off toggle.
   ============================================================ *@

<label class="toggle">
    <input type="checkbox" checked="@Value" @onchange="OnChange" disabled="@Disabled" />
    <span class="toggle-slider"></span>
</label>

@code {
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private async Task OnChange(ChangeEventArgs e)
    {
        var next = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;
        await ValueChanged.InvokeAsync(next);
    }
}

