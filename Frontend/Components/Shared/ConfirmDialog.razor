@namespace Frontend.Components.Shared

@* ============================================================
   KOMPONENT: ConfirmDialog
   FORMÅL: Genbrugelig bekræftelses-dialog (typisk til slet).
   ============================================================ *@

@if (IsOpen)
{
    <div class="confirm-overlay" role="dialog" aria-modal="true" aria-label="@Title" @onclick="OnBackdropClick">
        <div class="confirm-dialog" @onclick:stopPropagation="true">
            <div class="confirm-header">
                <h3>@Title</h3>
            </div>
            <div class="confirm-body">
                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <p>@Message</p>
                }

                @ChildContent
            </div>
            <div class="confirm-footer">
                <button class="btn-cancel" type="button" @onclick="Cancel">@CancelText</button>
                <button class="btn-confirm @ConfirmButtonClass" type="button" @onclick="Confirm">@ConfirmText</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter] public string Title { get; set; } = "Bekræft";
    [Parameter] public string? Message { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string CancelText { get; set; } = "Annuller";
    [Parameter] public string ConfirmText { get; set; } = "OK";
    [Parameter] public string ConfirmButtonClass { get; set; } = "danger";
    [Parameter] public bool CloseOnBackdrop { get; set; } = true;

    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task Confirm()
    {
        await OnConfirm.InvokeAsync();
        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task OnBackdropClick()
    {
        if (!CloseOnBackdrop) return;
        await Cancel();
    }
}

