@page "/residentadmin"
@using Plejecenter.WebApp.Components.Shared


<h2>Beboer Administration</h2>

<!-- Add Resident Section -->
<div class="add-resident-section">
  <div class="form-header">Tilføj Ny Beboer</div>
  <div class="form-row">
    <input type="text" placeholder="Fornavn" @bind="newResident.FirstName" />
    <input type="text" placeholder="Efternavn" @bind="newResident.LastName" />
    <input type="text" placeholder="Dashboard Initialer" @bind="newResident.Alias"/>
    <button class="btn-add-resident" @onclick="HandleAddResidentAsync">Tilføj</button>
  </div>
</div>

<!-- Residents Grid -->
<div class="residents-wrapper">
  @* <span class="scroll-arrow up">&#8743;</span> *@

  <div class="residents-grid" id="residentsGrid">


    @foreach (var resident in residents)
    {
        <ResidentCard
            FullName="@($"{resident.FirstName} {resident.LastName}")"
            Initials="@(resident.FirstName[0] + ". " + resident.LastName[0] + ".")"
		        MedicationTimes="@emptyList" />
    }


  </div><!-- end grid -->

 @*  <span class="scroll-arrow down">&#8744;</span> *@
</div>