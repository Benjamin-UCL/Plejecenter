@page "/residentadmin"
@using Plejecenter.Domain
@using Plejecenter.WebApp.Components.Shared


<h2>Beboer Administration</h2>

<!-- Add Resident Section -->
<div class="add-resident-section">
  <div class="form-header">Tilføj Ny Beboer</div>
  <div class="form-row">
    <input type="text" placeholder="Fornavn" @bind="newResident.FirstName" />
    <input type="text" placeholder="Efternavn" @bind="newResident.LastName" />
    <input type="text" placeholder="Dashboard Initialer" @bind="newResident.Alias"/>
    <button class="btn-add-resident" @onclick="HandleAddResidentAsync">Tilføj</button>
  </div>
</div>

<!-- Residents Grid -->
<div class="residents-wrapper">
  @* <span class="scroll-arrow up">&#8743;</span> *@

  <div class="residents-grid" id="residentsGrid">


    @foreach (var resident in residents)
    {
        <ResidentCard
            ResidentId="@resident.Id"
            FullName="@($"{resident.FirstName} {resident.LastName}")"
            Initials="@(resident.FirstName[0] + ". " + resident.LastName[0] + ".")"
		        MedicationTimes="@emptyList"
            OnDelete="HandleDeleteResidentAsync"
            OnEdit="HandleEditResidentAsync" />
    }


  </div><!-- end grid -->

 @*  <span class="scroll-arrow down">&#8744;</span> *@
</div>

@* --- MODALS BELOW --- *@

@if (showEditModal)
{
    <div class="modal-backdrop">
        <div class="edit-modal">
            <EditForm Model="@editingResident" OnValidSubmit="SaveEditAsync">
                <DataAnnotationsValidator />
                
                <div class="form-header">Rediger Beboer</div>
                
                <div class="form-body">
                    <div class="form-group">
                        <label>Fornavn</label>
                        <InputText class="form-control" @bind-Value="editingResident.FirstName" />
                        <ValidationMessage For="@(() => editingResident.FirstName)" />
                    </div>

                    <div class="form-group">
                        <label>Efternavn</label>
                        <InputText class="form-control" @bind-Value="editingResident.LastName" />
                        <ValidationMessage For="@(() => editingResident.LastName)" />
                    </div>

                    <div class="form-group">
                        <label>Initialer</label>
                        <InputText class="form-control" @bind-Value="editingResident.Alias" />
                        <ValidationMessage For="@(() => editingResident.Alias)" />
                    </div>
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn-cancel" @onclick="() => showEditModal = false">Annuller</button>
                    <button type="submit" class="btn-save">Gem Ændringer</button>
                </div>
            </EditForm>
        </div>
    </div>
}