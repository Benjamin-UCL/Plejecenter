@page "/residentadmin"
@using Plejecenter.Domain
@using Plejecenter.WebApp.Components.Shared


<div class="admin-main-wrapper">
    <div class="top-nav">
        <DateNavigator Date="currentDate" DateChanged="OnDateChanged" />
    </div>

    <div class="admin-content-grid">
        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <ResidentPicker 
            Residents="pickerResidents"
            SelectedResident="selectedPickerResident"
            SelectedResidentChanged="OnResidentSelected" />

            <div class="button-row">
                <button class="btn-add" @onclick="OpenAddModal">Tilføj</button>
                <button class="btn-edit" 
                    disabled="@(selectedResidentDto == null)" 
                    @onclick="() => HandleEditResidentAsync(selectedResidentDto!.Id)">Rediger</button>

                <button class="btn-delete" 
                    disabled="@(selectedResidentDto == null)" 
                    @onclick="() => HandleDeleteResidentAsync(selectedResidentDto!.Id)">Slet</button>
                        </div>
        </aside>

        <!-- Main Card -->
        <section class="admin-main-card">
            <DetailCard Resident="selectedResidentDto"
                        ResidentChanged="OnDetailChanged"
                        OnSaveRequested="SaveResidentDetailsAsync"
                        OnPnAdded="HandlePnAddedAsync"
                        OnPnDeleted="HandlePnDeletedAsync"
                        OnMedScheduleAdded="HandleMedAddedAsync"
                        OnMedScheduleDeleted="HandleMedDeletedAsync"
                        OnMedicationToggled="HandleMedicationToggledAsync"
                        />
        </section>

        <!-- Log -->
        <aside class="admin-log">
            <h3>Beboer log</h3>
            ...
        </aside>
    </div>
</div>


@* --- MODALS BELOW --- *@

@if (showEditModal)
{
    <div class="modal-backdrop">
        <div class="edit-modal">
            <EditForm Model="@editingResident" OnValidSubmit="SaveEditAsync">
                <DataAnnotationsValidator />
                
                <div class="form-header">Rediger Beboer</div>
                
                <div class="form-body">
                    <div class="form-group">
                        <label>Fornavn</label>
                        <InputText class="form-control" @bind-Value="editingResident.FirstName" />
                        <ValidationMessage For="@(() => editingResident.FirstName)" />
                    </div>

                    <div class="form-group">
                        <label>Efternavn</label>
                        <InputText class="form-control" @bind-Value="editingResident.LastName" />
                        <ValidationMessage For="@(() => editingResident.LastName)" />
                    </div>

                    <div class="form-group">
                        <label>Initialer</label>
                        <InputText class="form-control" @bind-Value="editingResident.Alias" />
                        <ValidationMessage For="@(() => editingResident.Alias)" />
                    </div>
                </div>

                <div class="modal-actions">
                    <button type="submit" class="btn-add">Gem Ændringer</button>
                    <button type="button" class="btn-delete" @onclick="() => showEditModal = false">Annuller</button>
                </div>
            </EditForm>
        </div>
    </div>
}