@namespace Plejecenter.WebApp.Components.Shared
@using Plejecenter.Shared.Enums

@* ============================================================
   KOMPONENT: ShiftSelector
   FORMÅL: Vagt tabs (Morgen/Eftermiddag/Nat) med aktiv markering.
   ============================================================ *@

<div class="vagt-selector-wrapper">
    <div class="vagt-selector-group">
        <button class="vagt-btn @(Value == ShiftType.Morgen ? "active" : "")" type="button"
                @onclick="() => Set(ShiftType.Morgen)">
            Morgenvagt (07-15)
        </button>
        <button class="vagt-btn @(Value == ShiftType.Eftermiddag ? "active" : "")" type="button"
                @onclick="() => Set(ShiftType.Eftermiddag)">
            Eftermiddagsvagt (15-23)
        </button>
        <button class="vagt-btn @(Value == ShiftType.Nat ? "active" : "")" type="button"
                @onclick="() => Set(ShiftType.Nat)">
            Nattevagt (23-07)
        </button>
    </div>

    @RightContent
</div>

@code {
    [Parameter] public ShiftType Value { get; set; }
    [Parameter] public EventCallback<ShiftType> ValueChanged { get; set; }
    [Parameter] public RenderFragment? RightContent { get; set; }

    private Task Set(ShiftType next) => ValueChanged.InvokeAsync(next);
}

