@* DetailCard.razor *@
@using Plejecenter.Domain
@using Plejecenter.Shared.Enums

@if (Resident is null)
{
    <div class="detail-empty">
        <p>Vælg en beboer for at se plejekortet</p>
    </div>
}
else
{
    <div class="detail-card">

        <div class="detail-header @StatusClass">
            <h2>@Resident.FirstName @Resident.LastName</h2>
            <div class="kritisk-wrap @StatusClass">
                <select class="kritisk-select"
                        value="@Resident.RiskLevel"
                        @onchange="OnStatusChanged"
                        aria-label="Status">
                    <option value="@RiskIndicator.High">Kritisk</option>
                    <option value="@RiskIndicator.Middle">Ustabil</option>
                    <option value="@RiskIndicator.Low">Stabil</option>
                </select>
            </div>
        </div>

        <div class="detail-body">

            <!-- MEDICIN -->
            <div>
                <div class="section-label">Medicin</div>
                <div class="pill-grid">
                    @foreach (var med in Resident.ScheduleMedications)
                    {
                        <label class="pill @(med.DispenseAt < DateTime.Now ? "pill-checked" : "")">
                            <input type="checkbox"
                                   checked="@(med.DispenseAt < DateTime.Now)"
                                   @onchange="() => OnMedGivenChanged(med)" />
                            @med.DispenseAt.ToString("HH:mm")
                        </label>
                    }
                </div>
            </div>

            <hr class="section-divider" />

            <!-- PN TID -->
            <div>
                <div class="pn-row">
                    <div class="section-label">PN – TID</div>
                    <div class="pn-actions">

                        @if (NextPnTime.HasValue)
                        {
                            <div class="pn-time-pill">
                                @NextPnTime.Value.ToString("HH:mm")
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     width="16" height="16"
                                     fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <path d="M12 6v6l4 2"></path>
                                </svg>
                            </div>
                        }

                        <button class="icon-btn green"
                                @onclick="AddPnEntry"
                                aria-label="Tilføj PN tid">
                            +
                        </button>

                    </div>
                </div>

                <div class="pill-grid">
                    @foreach (var pn in Resident.PatientTimes)
                    {
                        <label class="pill" title="@pn.Note">
                            @pn.DispensedAt.ToString("HH:mm")
                        </label>
                    }
                </div>
            </div>

            <hr class="section-divider" />

            <!-- HANDLEDAG + BETALING -->
            <div class="bottom-grid">

                <div class="bottom-col">
                    <label>Handledag</label>
                    <div class="select-wrap">
                        <select value="@Resident.ShoppingDay"
                                @onchange="e => Resident.ShoppingDay = e.Value?.ToString() ?? string.Empty">
                            <option value="">Dag</option>
                            <option value="Mandag">Mandag</option>
                            <option value="Tirsdag">Tirsdag</option>
                            <option value="Onsdag">Onsdag</option>
                            <option value="Torsdag">Torsdag</option>
                            <option value="Fredag">Fredag</option>
                        </select>
                    </div>
                    <textarea class="message-area"
                              placeholder="Indkøbsliste eller noter"
                              value="@Resident.ShoppingNotes"
                                  @onchange="e => Resident.ShoppingNotes = e.Value?.ToString() ?? string.Empty">
                    </textarea>
                    </div>

                    <div class="bottom-col">
                        <label>Betaling</label>
                        <textarea class="message-area"
                                  placeholder="Betalings information"
                                  value="@Resident.PaymentNotes"
                                      @onchange="e => Resident.PaymentNotes = e.Value?.ToString() ?? string.Empty">
                    </textarea>
                        </div>

                    </div>

                    <hr class="section-divider" />

                    <!-- MESSAGE -->
                    <div>
                        <textarea class="message-area full-width"
                                  placeholder="Tilføj besked eller opgave…"
                                  value="@Resident.Message"
                                      @onchange="e => Resident.Message = e.Value?.ToString() ?? string.Empty">
                </textarea>
                        </div>

        </div>

        <div class="detail-body">
            @* ... all your existing sections ... *@

            <div class="detail-actions">
                <button class="btn-save-detail" @onclick="HandleSaveClick">
                    Gem ændringer
                </button>
            </div>
        </div>

    </div>
}