<div class="card">

    @if (Header != null)
    {
        <div class="card-header">
            @Header
        </div>
    }

    <div class="card-body">
        @ChildContent
    </div>
</div>



@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter] 
    public RenderFragment? Header { get; set; }
}
